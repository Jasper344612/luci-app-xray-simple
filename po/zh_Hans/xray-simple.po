msgid "%s must be an integer between %s and %s"
msgstr "%s 必须是 %s 到 %s 之间的整数"

msgid "All Xray outbounds must set streamSettings.sockopt.mark to the Xray outbound bypass mark, otherwise traffic may loop back into TProxy. Current bypass mark: %s."
msgstr "所有 Xray 出站都必须将 streamSettings.sockopt.mark 设置为 Xray 出站绕过 mark，否则流量可能回环进入 TProxy。当前绕过 mark：%s。"

msgid "Important: "
msgstr "重要："

msgid "Outbound mark reminder"
msgstr "出站 mark 提醒"

msgid "Add a profile to import JSON, then use Switch & Restart for one-click switching."
msgstr "添加配置用于导入 JSON，然后使用切换并重启进行一键切换。"

msgid "Bypass GIDs"
msgstr "绕过 GID"

msgid "Bypass IPv4/CIDR"
msgstr "绕过 IPv4/CIDR"

msgid "Bypass IPv6/CIDR"
msgstr "绕过 IPv6/CIDR"

msgid "Bypass UIDs"
msgstr "绕过 UID"

msgid "Clear"
msgstr "清空"

msgid "Close"
msgstr "关闭"

msgid "Close command error"
msgstr "关闭命令错误"

msgid "Default geodata download directory. Xray Simple sets XRAY_LOCATION_ASSET to this directory when running Xray."
msgstr "默认 geodata 下载目录。Xray Simple 在运行 Xray 时会将 XRAY_LOCATION_ASSET 设置为此目录。"

msgid "Description"
msgstr "简介"

msgid "Download sources: "
msgstr "下载来源："

msgid "Enable Xray Simple"
msgstr "启用 Xray Simple"

msgid "Write Xray output to system log"
msgstr "将 Xray 输出写入系统日志"

msgid "Xray runtime log file"
msgstr "Xray 运行日志文件"

msgid "Absolute path used when system log output is disabled."
msgstr "关闭系统日志输出时使用的绝对路径。"

msgid "The runtime log path must be absolute."
msgstr "运行日志路径必须是绝对路径。"

msgid "When enabled, send Xray stdout and stderr to the OpenWrt system log. When disabled, keep them only in the Xray runtime log tab. Restart Xray after changing this setting."
msgstr "启用时将 Xray 的标准输出和错误输出写入 OpenWrt 系统日志；关闭时仅保留在 Xray 运行日志标签页中。修改此设置后需要重启 Xray。"

msgid "Export profile"
msgstr "导出配置"

msgid "Failed to read logs."
msgstr "读取日志失败。"

msgid "GID must be numeric"
msgstr "GID 必须是数字"

msgid "Geo database"
msgstr "Geo 数据库"

msgid "Geo database files found in %s."
msgstr "已在 %s 中找到 Geo 数据库文件。"

msgid "Geo database required: "
msgstr "需要 Geo 数据库："

msgid "Generated direct nftables rules"
msgstr "生成的 direct nftables 规则"

msgid "Generated firewall4 nftables rules"
msgstr "生成的 firewall4 nftables 规则"

msgid "IPv4 route table"
msgstr "IPv4 路由表"

msgid "IPv6 route table"
msgstr "IPv6 路由表"

msgid "Invalid CIDR prefix length"
msgstr "CIDR 前缀长度无效"

msgid "Invalid CIDR value"
msgstr "CIDR 值无效"

msgid "Invalid IPv4/CIDR value"
msgstr "IPv4/CIDR 值无效"

msgid "Invalid IPv6/CIDR value"
msgstr "IPv6/CIDR 值无效"

msgid "Invalid network interface name"
msgstr "网络接口名称无效"

msgid "LAN interfaces"
msgstr "LAN 接口"

msgid "Loading…"
msgstr "加载中…"

msgid "Logs"
msgstr "日志"

msgid "Minimal Xray TProxy management. Xray JSON remains user-owned; this page only manages process and TProxy plumbing."
msgstr "最小化的 Xray TProxy 管理。Xray JSON 仍由用户维护；本页面只管理进程和 TProxy 管线。"

msgid "Missing %s in %s. If your JSON uses geoip: or geosite: rules, install geodata packages or download the files and place them in this directory."
msgstr "缺少 %s，目录：%s。如果你的 JSON 使用 geoip: 或 geosite: 规则，请安装 geodata 软件包，或者下载文件并放到这个目录。"

msgid "No description"
msgstr "无简介"

msgid "No generated rules yet"
msgstr "尚未生成规则"

msgid "No recent Xray log entries found."
msgstr "暂无近期 Xray 日志记录。"

msgid "OK"
msgstr "确定"

msgid "Policy routing mark"
msgstr "策略路由 mark"

msgid "Policy routing mark and Xray outbound bypass mark must be different."
msgstr "策略路由 mark 与 Xray 出站绕过 mark 不能相同。"

msgid "UID"
msgstr "UID"

msgid "GID"
msgstr "GID"

msgid "Process Management"
msgstr "进程管理"

msgid "Profile JSON"
msgstr "配置 JSON"

msgid "Profile actions"
msgstr "配置操作"

msgid "Profile name"
msgstr "配置名称"

msgid "Profile save failed"
msgstr "配置保存失败"

msgid "Profile switch failed"
msgstr "切换配置失败"

msgid "Profile deletion failed"
msgstr "删除配置失败"

msgid "At least one Xray profile is required."
msgstr "至少需要保留一个 Xray 配置。"

msgid "At least one LAN interface is required."
msgstr "至少需要配置一个 LAN 接口。"

msgid "Proxy LAN DNS UDP/53 directly through TProxy"
msgstr "通过 TProxy 直接代理 LAN DNS UDP/53"

msgid "Use dnsmasq as Xray DNS frontend"
msgstr "使用 dnsmasq 作为 Xray DNS 前端"

msgid "dnsmasq upstream"
msgstr "dnsmasq 上游"

msgid "Configure"
msgstr "配置"

msgid "Active"
msgstr "已激活"

msgid "Inactive"
msgstr "未激活"

msgid "Disabled"
msgstr "已禁用"

msgid "Navigation"
msgstr "导航"

msgid "Back to Xray Simple"
msgstr "返回 Xray Simple"

msgid "Activation status"
msgstr "激活状态"

msgid "Enable dnsmasq upstream"
msgstr "启用 dnsmasq 上游"

msgid "Use dnsmasq as the LAN DNS frontend and forward its queries to a local Xray DNS inbound."
msgstr "使用 dnsmasq 作为 LAN DNS 前端，并将查询转发到本地 Xray DNS 入站。"

msgid "Redirect LAN UDP/53 to dnsmasq and use the local Xray DNS inbound as upstream. Restart Xray after changing this setting."
msgstr "将 LAN UDP/53 重定向到 dnsmasq，并使用本地 Xray DNS 入站作为上游。修改此设置后请重启 Xray。"

msgid "Runtime behavior"
msgstr "运行行为"

msgid "Xray Simple keeps /etc/config/dhcp unchanged. It installs a temporary dnsmasq fragment only while Xray is running and removes it when Xray stops or fails to start."
msgstr "Xray Simple 不会修改 /etc/config/dhcp。仅在 Xray 运行时安装临时 dnsmasq 配置片段，并在 Xray 停止或启动失败时将其删除。"

msgid "dnsmasq status unavailable"
msgstr "dnsmasq 状态不可用"

msgid "Required Xray JSON configuration"
msgstr "所需的 Xray JSON 配置"

msgid "Merge the following inbound, routing rule, and outbound into the active Xray JSON yourself. The configured Xray DNS inbound port must match this inbound, and the existing top-level dns configuration must define the required upstream servers."
msgstr "请自行将以下入站、路由规则和出站合并到当前 Xray JSON。配置的 Xray DNS 入站端口必须与此入站一致，并且现有的顶层 dns 配置必须定义所需的上游服务器。"

msgid "Redirect LAN UDP/53 to dnsmasq and use the local Xray DNS inbound as upstream. Enabling this option automatically disables direct LAN DNS UDP/53 TProxy. Restart Xray after changing this setting."
msgstr "将 LAN UDP/53 重定向到 dnsmasq，并使用本地 Xray DNS 入站作为上游。启用此选项会自动关闭通过 TProxy 直接代理 LAN DNS UDP/53。修改后请重启 Xray。"

msgid "Redirect LAN UDP/53 to dnsmasq and use the local Xray DNS inbound as the only upstream. Xray Simple restores the original dnsmasq upstream when Xray stops."
msgstr "将 LAN UDP/53 重定向到 dnsmasq，并使用本地 Xray DNS 入站作为上游。Xray 停止时，Xray Simple 会恢复 dnsmasq 原有的上游。"

msgid "Xray DNS inbound port"
msgstr "Xray DNS 入站端口"

msgid "The active Xray JSON must provide a DNS inbound listening on 127.0.0.1 at this port. Port 53 is reserved for dnsmasq."
msgstr "当前 Xray JSON 必须提供一个在 127.0.0.1 此端口监听的 DNS 入站。端口 53 保留给 dnsmasq。"

msgid "Port 53 is reserved for dnsmasq"
msgstr "端口 53 保留给 dnsmasq"

msgid "Proxy router-local traffic"
msgstr "代理路由器本机流量"

msgid "Refresh"
msgstr "刷新"

msgid "Restart"
msgstr "重启"

msgid "Rule loading mode"
msgstr "规则加载模式"

msgid "Route tables 253, 254, and 255 are reserved"
msgstr "路由表 253、254 和 255 为系统保留表"

msgid "Show nftables status"
msgstr "显示 nftables 状态"

msgid "Start"
msgstr "启动"

msgid "Start TProxy"
msgstr "启动 TProxy"

msgid "Stop"
msgstr "停止"

msgid "Stop TProxy"
msgstr "停止 TProxy"

msgid "Switch & Restart"
msgstr "切换并重启"

